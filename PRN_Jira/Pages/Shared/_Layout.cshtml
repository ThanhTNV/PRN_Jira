<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PRN_Jira</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
</head>
<body>
<nav class="navbar navbar-expand-lg navbar-dark bg-dark">
    <div class="container">
        <a class="navbar-brand" asp-page="/Index">PRN_Jira</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#nav">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="nav">
            <ul class="navbar-nav me-auto">
                <li class="nav-item"><a class="nav-link" asp-page="/Projects/Index">Projects</a></li>
                <li class="nav-item"><a class="nav-link" asp-page="/Jira/Setup">Jira Setup</a></li>
                <li class="nav-item"><a class="nav-link" asp-page="/SrsDocuments/Index">SRS</a></li>
            </ul>
            <ul class="navbar-nav">
                <li class="nav-item"><a class="nav-link" href="/swagger">Swagger</a></li>
                @if (User?.Identity?.IsAuthenticated ?? false)
                {
                    <li class="nav-item">
                        <span class="navbar-text ms-2 text-white-50">@User.Identity!.Name</span>
                    </li>
                    <li class="nav-item ms-2">
                        <form method="post" asp-page="/Auth/Logout" class="d-inline">
                            <button class="btn btn-sm btn-outline-light" type="submit">Logout</button>
                        </form>
                    </li>
                }
                else
                {
                    <li class="nav-item"><a class="nav-link" asp-page="/Auth/Login">Login</a></li>
                    <li class="nav-item"><a class="nav-link" asp-page="/Auth/Register">Register</a></li>
                }
            </ul>
        </div>
    </div>
</nav>

<main class="container py-4">
    @RenderBody()
</main>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
